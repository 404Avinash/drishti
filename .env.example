# ─────────────────────────────────────────────────────────────────────────────
# DRISHTI — Environment Variables Template
# Copy this file: cp .env.example .env
# NEVER commit .env to git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── API Server ───────────────────────────────────────────────────────────────
PORT=8000
UVICORN_WORKERS=1            # 1 for dev, 2-4 for production
API_HOST=0.0.0.0

# ── Redis (optional — system works without it, uses in-memory fallback) ───────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=3

# ── Data Sources (OSINT) ─────────────────────────────────────────────────────
# NTES scraping (optional live data — system uses statistical simulation if empty)
NTES_TIMEOUT_SECONDS=3
NTES_RETRY_BACKOFF=2
OSINT_POLL_INTERVAL_SECONDS=120

# ── Simulation Engine ────────────────────────────────────────────────────────
STREAMING_BACKEND=mock       # mock | live (live = attempt NTES scraping)
SIMULATION_TICK_SECONDS=5    # How often the cascade engine steps
CASCADE_DECAY_RATE=0.15      # How fast delays decay per tick (0.0–1.0)
SIGNATURE_MATCH_THRESHOLD=40 # % above which a CRS match triggers alert

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production-minimum-32-chars-random
ALERT_SIGNING_KEY=          # Ed25519 key for alert signing (auto-generated if empty)

# ── Frontend ─────────────────────────────────────────────────────────────────
# These are read at build time by Vite — prefix must be VITE_
VITE_API_URL=               # Empty = use relative URL (works through Nginx proxy)
VITE_WS_PORT=8000           # Only needed when running frontend without proxy
VITE_APP_VERSION=dev

# ── Monitoring (optional) ────────────────────────────────────────────────────
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ── Deployment: Render.com ────────────────────────────────────────────────────
# Set these in GitHub Secrets for the CD pipeline:
# RENDER_DEPLOY_HOOK       → webhook URL from Render dashboard
# RENDER_API_KEY           → from Render account settings
# RENDER_SERVICE_ID        → from Render service URL

# ── Deployment: Docker ────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io
IMAGE_TAG=latest

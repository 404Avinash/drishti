# ─────────────────────────────────────────────────────────────────────────────
# DRISHTI — Free-Tier Environment Profile
# Stack: Render (compute) + Upstash (Redis) + Neon/Supabase (Postgres, optional)
#
# Copy this: cp .env.free-tier .env
# Then fill in the values marked ← FILL IN
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8000
UVICORN_WORKERS=1               # Keep at 1 on free tier (512MB RAM limit)

# ── Redis: Upstash (free tier — 10k commands/day, no cold start) ──────────────
# Get your URL from: https://console.upstash.com → Create Database → Redis
# Format: rediss://:PASSWORD@ENDPOINT:PORT
REDIS_URL=rediss://:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_ENDPOINT:6379   # ← FILL IN
REDIS_MAX_CONNECTIONS=5         # Low to stay within free tier limits
REDIS_SOCKET_TIMEOUT=5

# ── Database: Neon (free tier — 0.5 GB storage, no sleeping) ─────────────────
# Get your URL from: https://console.neon.tech → Create Project → Connection string
# Alternative: Supabase (https://app.supabase.com → Project → Settings → Database)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require  # ← FILL IN (or leave empty — SQLite fallback is used)

# ── Simulation Engine ─────────────────────────────────────────────────────────
STREAMING_BACKEND=mock          # Keep 'mock' on free tier — live NTES needs proxying
SIMULATION_TICK_SECONDS=10      # Slower tick = less CPU on free tier (default: 5)
CASCADE_DECAY_RATE=0.15
SIGNATURE_MATCH_THRESHOLD=40

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_USE_COMMAND_ABOVE   # ← FILL IN

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
VITE_API_URL=                   # Empty = use relative URL (works via Render rewrites)
VITE_APP_VERSION=free-tier

# ── Render-specific Secrets (for CI/CD — set in GitHub Secrets, NOT here) ────
# RENDER_DEPLOY_HOOK_API         → Render dashboard → drishti-api → Settings → Deploy Hook
# RENDER_DEPLOY_HOOK_FRONTEND    → Render dashboard → drishti-frontend → Settings → Deploy Hook
# RENDER_HEALTH_URL              → Override health check base URL (optional)

# ── Free Tier Limits Reference ────────────────────────────────────────────────
# Render Free:   512MB RAM, sleeps after 15min inactivity (cold start ~30-90s)
# Upstash Free:  10,000 commands/day, 256MB storage, no idle sleep
# Neon Free:     0.5 GB storage, 1 compute unit, auto-suspend after 5min
# Supabase Free: 500MB storage, pauses after 1 week inactivity
# GitHub Actions Free: 2,000 minutes/month (Linux), unlimited public repos
